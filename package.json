{
  "name": "data-extractor",
  "version": "1.0.0",
  "description": "Simple Express.js REST API with Prisma and SQLite",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:client": "npm --prefix client run dev",
    "dev:all": "npm-run-all --parallel dev dev:client",
    "build:client": "npm --prefix client run build",
    "db:migrate": "prisma migrate dev --name init",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "npm-run-all": "^4.1.5",
    "prisma": "^5.10.0"
  }
}
